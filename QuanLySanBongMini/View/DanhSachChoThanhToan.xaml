<UserControl x:Class="QuanLySanBongMini.View.DanhSachChoThanhToanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- DataGrid header style -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#2E7D32"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <!-- Row style -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Nút xanh -->
        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background"  Value="#2E7D32"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Height"      Value="38"/>
            <Setter Property="Padding"     Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A5D6A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Nút đỏ -->
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background"  Value="#EF4444"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Height"      Value="38"/>
            <Setter Property="Padding"     Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DC2626"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#2E7D32" Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🕐" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="DANH SÁCH CHỜ THANH TOÁN"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Các lượt đặt sân chưa thanh toán — Đã đặt &amp; Đang đá"
                               FontSize="12" Foreground="#A5D6A7" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="White" BorderBrush="#C8E6C9"
                BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tìm kiếm -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 Tìm kiếm:" FontSize="13" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                             Width="260" Height="34" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="13"
                             BorderBrush="#C8E6C9">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="(tên KH, SĐT, tên sân)" FontSize="11"
                               Foreground="#9CA3AF" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Làm mới -->
                <Button Grid.Column="1" Content="🔄 Làm mới"
                        Command="{Binding LamMoiCommand}"
                        Style="{StaticResource BtnGreen}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DanhSach}"
                  SelectedItem="{Binding DongDangChon}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E8F5E9"
                  BorderThickness="0"
                  ColumnHeaderStyle="{StaticResource HeaderStyle}"
                  RowStyle="{StaticResource RowStyle}"
                  SelectionMode="Single"
                  FontSize="13"
                  CanUserResizeColumns="False"
                  CanUserReorderColumns="False"
                  Margin="16,12,16,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã ĐS"      Binding="{Binding MaDatSan}"      Width="65"/>
                <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}"  Width="*"/>
                <DataGridTextColumn Header="Số ĐT"      Binding="{Binding SoDienThoai}"   Width="120"/>
                <DataGridTextColumn Header="Sân"        Binding="{Binding TenSan}"        Width="90"/>
                <DataGridTextColumn Header="Thời gian"  Binding="{Binding ThoiGian}"      Width="200"/>
                <DataGridTextColumn Header="Tổng tiền"  Binding="{Binding TongTienFormatted}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#EF4444"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Cột Trạng thái dùng template để tô màu -->
                <DataGridTemplateColumn Header="Trạng thái" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="10,3" HorizontalAlignment="Center"
                                    Background="{Binding MauTrangThai}">
                                <TextBlock Text="{Binding TrangThai}"
                                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- FOOTER ACTIONS -->
        <Border Grid.Row="3" Background="White" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Thông tin dòng đang chọn -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Đang chọn: " FontSize="13" Foreground="#6B7280"/>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1F2937">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DongDangChon}" Value="{x:Null}">
                                        <Setter Property="Text" Value="(chưa chọn)"/>
                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding DongDangChon.TenKhachHang, FallbackValue=''}"/>
                        <Run Text=" — "/>
                        <Run Text="{Binding DongDangChon.TenSan, FallbackValue=''}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Nút Hủy -->
                <Button Grid.Column="1"
                        Content="❌  Hủy đặt sân"
                        Command="{Binding HuyDatSanCommand}"
                        Style="{StaticResource BtnRed}"/>

                <!-- Nút Thanh toán -->
                <Button Grid.Column="3"
                        Content="💳  Thanh toán"
                        Command="{Binding ThanhToanCommand}"
                        Style="{StaticResource BtnGreen}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
