<UserControl x:Class="QuanLySanBongMini.View.DatSanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLySanBongMini.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="LightGray" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅 Ngày:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding NgayLoc}" Width="130" Height="35" VerticalContentAlignment="Center"/>

                    <TextBlock Text="⚽ Loại sân:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4B5563" Margin="20,0,10,0"/>
                    <ComboBox Width="120" Height="35" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                        <ComboBoxItem Content="Sân 5 người"/>
                        <ComboBoxItem Content="Sân 7 người"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DanhSachSan}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="160" Height="140" Margin="0,0,15,15" Background="White" CornerRadius="8" Cursor="Hand">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="Gray" Opacity="0.3"/>
                                </Border.Effect>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding DataContext.ChonSanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="30"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#10B981" CornerRadius="8,8,0,0">
                                        <TextBlock Text="{Binding TenSan}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                    </Border>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TrangThai}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#1F2937"/>
                                        <TextBlock Text="{Binding LoaiSan}" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <Border Grid.Row="2" Background="#F3F4F6" CornerRadius="0,0,8,8">
                                        <TextBlock Text="{Binding GiaThueGio, StringFormat='{}{0:N0} đ/h'}" Foreground="#EF4444" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="LightGray" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="THÔNG TIN ĐẶT SÂN" FontSize="18" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Sân đang chọn:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SanDangChon.TenSan}" IsReadOnly="True" Background="#F3F4F6" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15" BorderBrush="#D1D5DB"/>

                    <TextBlock Text="Tên khách hàng (*):" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TenKhachHang, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15" BorderBrush="#D1D5DB"/>

                    <TextBlock Text="Số điện thoại (*):" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15" BorderBrush="#D1D5DB"/>

                    <TextBlock Text="Giờ bắt đầu:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <ComboBox SelectedValue="{Binding GioBatDau, Mode=TwoWay}"
                              ItemsSource="{Binding DanhSachGio}"
                              Height="35" VerticalContentAlignment="Center"
                              Margin="0,0,0,15" BorderBrush="#D1D5DB"
                              FontSize="14"/>

                    <TextBlock Text="Giờ kết thúc:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <ComboBox SelectedValue="{Binding GioKetThuc, Mode=TwoWay}"
                              ItemsSource="{Binding DanhSachGio}"
                              Height="35" VerticalContentAlignment="Center"
                              Margin="0,0,0,15" BorderBrush="#D1D5DB"
                              FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Button Content="ĐẶT SÂN TRƯỚC" Command="{Binding DatSanCommand}" Height="40" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="NHẬN SÂN (BẮT ĐẦU ĐÁ)" Command="{Binding NhanSanCommand}" Height="40" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
