<Window x:Class="QuanLySanBongMini.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng Nhập - Sân Bóng Mini"
        Height="520" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F0FDF4">

    <Border Background="White" CornerRadius="12" Margin="20" Padding="30,25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#10B981" Opacity="0.15"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center">

            <!-- Logo + Tên hệ thống -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="⚽" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="SÂN BÓNG MINI" FontSize="18" FontWeight="Bold"
                           Foreground="#065F46" HorizontalAlignment="Center"/>
                <TextBlock Text="Hệ thống quản lý" FontSize="12"
                           Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Tên đăng nhập -->
            <TextBlock Text="Tên đăng nhập" FontSize="13" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,6"/>
            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                <TextBox Text="{Binding MaNV, UpdateSourceTrigger=PropertyChanged}"
                         Height="38" Padding="12,0" FontSize="14"
                         VerticalContentAlignment="Center"
                         BorderThickness="0" Background="Transparent"/>
            </Border>

            <!-- Mật khẩu -->
            <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,6"/>
            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Margin="0,0,0,22">
                <PasswordBox x:Name="txtMatKhau"
                             Height="38" Padding="12,0" FontSize="14"
                             VerticalContentAlignment="Center"
                             BorderThickness="0" Background="Transparent"
                             PasswordChanged="txtMatKhau_PasswordChanged"/>
            </Border>

            <!-- Nút đăng nhập -->
            <Button Command="{Binding DangNhapCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="42" Background="#10B981" Foreground="White"
                    FontSize="14" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#059669"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Content>
                    <TextBlock Text="🔓  ĐĂNG NHẬP" FontSize="14" FontWeight="Bold"/>
                </Button.Content>
            </Button>

            <!-- Thông báo lỗi -->
            <TextBlock Text="{Binding ThongBao}" Foreground="#EF4444"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       TextWrapping="Wrap" TextAlignment="Center"
                       FontSize="12" FontWeight="SemiBold"/>
        </StackPanel>
    </Border>
</Window>
