<UserControl x:Class="QuanLySanBongMini.View.QuanLyMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F59E0B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FDE68A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#F59E0B" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🍔" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="QUẢN LÝ MENU ĐỒ ĂN / ĐỒ UỐNG"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Thêm, sửa, xóa các món phục vụ khách hàng"
                               FontSize="12" Foreground="#FEF3C7" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- FORM NHẬP -->
        <Border Grid.Row="1" Background="White" BorderBrush="#FDE68A"
                BorderThickness="0,0,0,2" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Tên món (*)" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TenMon, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#FDE68A" FontSize="13">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Loại (*)" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding LoaiMon, Mode=TwoWay}"
                              Height="36" VerticalContentAlignment="Center"
                              BorderBrush="#FDE68A" FontSize="13"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="Đồ uống"/>
                        <ComboBoxItem Content="Đồ ăn"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Đơn giá (*)" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#FDE68A" FontSize="13">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Mô tả" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MoTa, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#FDE68A" FontSize="13">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <!-- Còn hàng checkbox -->
                <StackPanel Grid.Column="4" Margin="0,0,10,0" VerticalAlignment="Bottom">
                    <CheckBox Content="Còn hàng" IsChecked="{Binding ConHang}"
                              Height="36" VerticalContentAlignment="Center"
                              FontSize="13" Cursor="Hand"/>
                </StackPanel>

                <!-- Nút -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="➕ Thêm"  Command="{Binding ThemCommand}"
                            Background="#10B981" Foreground="White"
                            Style="{StaticResource BtnStyle}" Margin="0,0,6,0"/>
                    <Button Content="✏️ Sửa"  Command="{Binding SuaCommand}"
                            Background="#F59E0B" Foreground="White"
                            Style="{StaticResource BtnStyle}" Margin="0,0,6,0"/>
                    <Button Content="🗑️ Xóa"  Command="{Binding XoaCommand}"
                            Background="#EF4444" Foreground="White"
                            Style="{StaticResource BtnStyle}" Margin="0,0,6,0"/>
                    <Button Content="🔄"       Command="{Binding LamMoiCommand}"
                            Background="#6B7280" Foreground="White"
                            Style="{StaticResource BtnStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DANH SÁCH -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Tìm kiếm:" FontSize="13" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                             Width="260" Height="32" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="13" BorderBrush="#FDE68A">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></TextBox.Resources>
                    </TextBox>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding DanhSachMon}"
                      SelectedItem="{Binding MonDangChon}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#FEF3C7"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                      RowStyle="{StaticResource RowStyle}"
                      SelectionMode="Single" FontSize="13"
                      CanUserResizeColumns="False" CanUserReorderColumns="False"
                      Margin="16,0,16,16">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã"      Binding="{Binding MaMon}"  Width="55"/>
                    <DataGridTextColumn Header="Tên món" Binding="{Binding TenMon}" Width="*"/>

                    <!-- Cột Loại — badge màu -->
                    <DataGridTemplateColumn Header="Loại" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LoaiMon}" Value="Đồ ăn">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding LoaiMon}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LoaiMon}" Value="Đồ ăn">
                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Đơn giá"
                                        Binding="{Binding DonGia, StringFormat='{}{0:N0} đ'}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding"             Value="0,0,8,0"/>
                                <Setter Property="FontWeight"          Value="SemiBold"/>
                                <Setter Property="Foreground"          Value="#EF4444"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Mô tả" Binding="{Binding MoTa}" Width="200"/>

                    <!-- Cột Trạng thái — badge màu -->
                    <DataGridTemplateColumn Header="Trạng thái" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#D1FAE5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConHang}" Value="False">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Còn hàng"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConHang}" Value="False">
                                                        <Setter Property="Text"       Value="Hết hàng"/>
                                                        <Setter Property="Foreground" Value="#991B1B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
