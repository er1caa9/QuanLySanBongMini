<UserControl x:Class="QuanLySanBongMini.View.ThongKeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLySanBongMini.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <!-- ============================================================
             MÀU SẮC CHỦ ĐẠO
        ============================================================ -->
        <Color x:Key="GreenPrimary">#2E7D32</Color>
        <Color x:Key="GreenLight">#4CAF50</Color>
        <Color x:Key="GreenPale">#E8F5E9</Color>
        <Color x:Key="GreenAccent">#81C784</Color>
        <Color x:Key="White">#FFFFFF</Color>
        <Color x:Key="TextDark">#1B2631</Color>
        <Color x:Key="TextGray">#6B7280</Color>
        <Color x:Key="BorderColor">#C8E6C9</Color>

        <SolidColorBrush x:Key="GreenPrimaryBrush"  Color="{StaticResource GreenPrimary}"/>
        <SolidColorBrush x:Key="GreenLightBrush"    Color="{StaticResource GreenLight}"/>
        <SolidColorBrush x:Key="GreenPaleBrush"     Color="{StaticResource GreenPale}"/>
        <SolidColorBrush x:Key="GreenAccentBrush"   Color="{StaticResource GreenAccent}"/>
        <SolidColorBrush x:Key="WhiteBrush"         Color="{StaticResource White}"/>
        <SolidColorBrush x:Key="TextDarkBrush"      Color="{StaticResource TextDark}"/>
        <SolidColorBrush x:Key="TextGrayBrush"      Color="{StaticResource TextGray}"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>

        <!-- ============================================================
             CONVERTER
        ============================================================ -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ============================================================
             STYLE: Thẻ KPI (Card tổng quan)
        ============================================================ -->
        <Style x:Key="KpiCardStyle" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource WhiteBrush}"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="Padding"          Value="20,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                      Color="#C8E6C9" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- STYLE: Tiêu đề section -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="15"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Foreground"       Value="{StaticResource GreenPrimaryBrush}"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <!-- STYLE: Nút bấm chính -->
        <Style x:Key="BtnPrimaryStyle" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource GreenPrimaryBrush}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="16,8"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource GreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- STYLE: Nút thứ cấp -->
        <Style x:Key="BtnSecondaryStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource GreenPrimaryBrush}"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="14,7"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="BorderBrush"      Value="{StaticResource GreenPrimaryBrush}"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource GreenPaleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- STYLE: Quick-filter button (chip) -->
        <Style x:Key="ChipStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource GreenPrimaryBrush}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource GreenAccentBrush}"/>
            <Setter Property="Margin"           Value="4,0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource GreenPaleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- STYLE: DataGrid header -->
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="{StaticResource GreenPrimaryBrush}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="12,10"/>
            <Setter Property="BorderThickness"  Value="0"/>
        </Style>

        <!-- STYLE: DataGrid row -->
        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="Margin"           Value="0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GreenPaleBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- STYLE: DatePicker -->
        <Style TargetType="DatePicker">
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

    </UserControl.Resources>

    <!-- ================================================================
         NỘI DUNG CHÍNH
    ================================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Bộ lọc -->
            <RowDefinition Height="Auto"/>
            <!-- KPI Cards -->
            <RowDefinition Height="*"/>
            <!-- Bảng thống kê -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ==============================================================
             ROW 0 — HEADER
        ============================================================== -->
        <Border Grid.Row="0"
                Background="{StaticResource GreenPrimaryBrush}"
                Padding="28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Icon sân bóng -->
                    <Viewbox Width="34" Height="34" Margin="0,0,12,0">
                        <Canvas Width="48" Height="48">
                            <!-- Hình tròn bóng đá -->
                            <Ellipse Width="44" Height="44" Canvas.Left="2" Canvas.Top="2"
                                     Stroke="White" StrokeThickness="3" Fill="Transparent"/>
                            <!-- Đường giữa sân -->
                            <Line X1="24" Y1="2" X2="24" Y2="46"
                                  Stroke="White" StrokeThickness="2"/>
                            <!-- Vòng tròn giữa sân -->
                            <Ellipse Width="16" Height="16" Canvas.Left="16" Canvas.Top="16"
                                     Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                        </Canvas>
                    </Viewbox>

                    <StackPanel>
                        <TextBlock Text="THỐNG KÊ &amp; BÁO CÁO"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Quản lý sân bóng mini — Phân tích doanh thu &amp; hoạt động"
                                   FontSize="12" Foreground="#A5D6A7" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nút xuất báo cáo -->
                <Button Grid.Column="1"
                        Command="{Binding XuatBaoCaoCommand}"
                        Style="{StaticResource BtnSecondaryStyle}"
                        Foreground="White"
                        BorderBrush="White"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="14" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Xuất báo cáo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ==============================================================
             ROW 1 — BỘ LỌC THỜI GIAN
        ============================================================== -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bộ lọc nhanh (chips) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Lọc nhanh:" FontSize="13"
                               Foreground="{StaticResource TextGrayBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="Hôm nay"   Style="{StaticResource ChipStyle}"
                            Command="{Binding LocTheoKyCommand}" CommandParameter="Hôm nay"/>
                    <Button Content="Tuần này"  Style="{StaticResource ChipStyle}"
                            Command="{Binding LocTheoKyCommand}" CommandParameter="Tuần này"/>
                    <Button Content="Tháng này" Style="{StaticResource ChipStyle}"
Command="{Binding LocTheoKyCommand}" CommandParameter="Tháng này"/>
                    <Button Content="Quý này"   Style="{StaticResource ChipStyle}"
                            Command="{Binding LocTheoKyCommand}" CommandParameter="Quý này"/>
                    <Button Content="Năm nay"   Style="{StaticResource ChipStyle}"
                            Command="{Binding LocTheoKyCommand}" CommandParameter="Năm nay"/>
                </StackPanel>

                <!-- Khoảng ngày tùy chọn -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Từ ngày:" FontSize="13"
                               Foreground="{StaticResource TextGrayBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding TuNgay, Mode=TwoWay}"
                                Width="130"/>
                    <TextBlock Text="→" FontSize="16" Margin="10,0"
                               Foreground="{StaticResource GreenPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Đến ngày:" FontSize="13"
                               Foreground="{StaticResource TextGrayBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding DenNgay, Mode=TwoWay}"
                                Width="130"/>
                </StackPanel>

                <!-- Nút làm mới -->
                <Button Grid.Column="2"
                        Command="{Binding LamMoiCommand}"
                        Style="{StaticResource BtnPrimaryStyle}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="13" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Xem thống kê" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ==============================================================
             ROW 2 — KPI CARDS
        ============================================================== -->
        <UniformGrid Grid.Row="2" Columns="5" Margin="20,16,20,0">

            <!-- Card 1: Tổng doanh thu -->
            <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="💰" FontSize="22"
HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource GreenPaleBrush}"
                                CornerRadius="6" Padding="6,3"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding DoanhThuTangTruongFormatted}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource GreenPrimaryBrush}"/>
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding TongDoanhThuFormatted}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource GreenPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Grid.Row="2"
                               Text="Tổng doanh thu"
                               FontSize="12" Foreground="{StaticResource TextGrayBrush}"/>
                </Grid>
            </Border>

            <!-- Card 2: Tổng lượt đặt -->
            <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📅" FontSize="22"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding TongLuotDat}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource GreenPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBlock Text="Lượt đặt sân"
                                   FontSize="12" Foreground="{StaticResource TextGrayBrush}"/>
                        <TextBlock Text="{Binding LuotDatTangTruongFormatted}"
                                   FontSize="11" Foreground="{StaticResource GreenLightBrush}"
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 3: Doanh thu trung bình/ngày -->
            <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📈" FontSize="22"/>
                    <TextBlock Grid.Row="1"
Text="{Binding DoanhThuTrungBinhNgayFormatted}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource GreenPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Grid.Row="2"
                               Text="TB doanh thu / ngày"
                               FontSize="12" Foreground="{StaticResource TextGrayBrush}"/>
                </Grid>
            </Border>

            <!-- Card 4: Sân phổ biến nhất -->
            <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="⚽" FontSize="22"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding SanPhoBienNhat}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource GreenPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Grid.Row="2"
                               Text="Sân được đặt nhiều nhất"
                               FontSize="12" Foreground="{StaticResource TextGrayBrush}"/>
                </Grid>
            </Border>

            <!-- Card 5: Khách mới -->
            <Border Style="{StaticResource KpiCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="👥" FontSize="22"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding SoKhachMoi}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource GreenPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Grid.Row="2"
                               Text="Khách hàng mới"
                               FontSize="12" Foreground="{StaticResource TextGrayBrush}"/>
                </Grid>
            </Border>

        </UniformGrid>

        <!-- ==============================================================
             ROW 3 — BẢNG THỐNG KÊ (3 bảng)
        ============================================================== -->
        <Grid Grid.Row="3" Margin="20,14,20,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Bảng thống kê theo sân -->
                <Border Grid.Row="0"
                        Background="White"
                        CornerRadius="12"
                        Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                          Color="#C8E6C9" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <TextBlock Text="⚽" FontSize="16" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Thống kê theo sân"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DanhSachThongKeSan}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                  BorderThickness="0"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  RowStyle="{StaticResource GridRowStyle}"
                                  SelectionMode="Single"
                                  FontSize="13"
                                  CanUserResizeColumns="False"
                                  CanUserReorderColumns="False">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên sân"
                                                    Binding="{Binding TenSan}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Lượt đặt"
                                                    Binding="{Binding SoLuotDat}"
                                                    Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Doanh thu"
                                                    Binding="{Binding DoanhThuFormatted}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Tỉ lệ"
                                                    Binding="{Binding TyLeSuDungFormatted}"
                                                    Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Thống kê theo ngày (7 ngày gần nhất) -->
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                          Color="#C8E6C9" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <TextBlock Text="📆" FontSize="16" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="7 ngày gần nhất"
Style="{StaticResource SectionTitleStyle}"
                                       Margin="0"/>
                        </StackPanel>

                        <!-- Bảng thống kê 7 ngày -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ThongKeTheoNgay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                  BorderThickness="0"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  RowStyle="{StaticResource GridRowStyle}"
                                  FontSize="13"
                                  CanUserResizeColumns="False"
                                  CanUserReorderColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ngày"
                                                    Binding="{Binding Ngay}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Lượt đặt"
                                                    Binding="{Binding SoLuotDat}"
                                                    Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Doanh thu"
                                                    Binding="{Binding DoanhThuFormatted}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>


            <Border Grid.Column="2"
Background="White"
                    CornerRadius="12"
                    Padding="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                      Color="#C8E6C9" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="🏆" FontSize="16" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Top khách hàng thân thiết"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{StaticResource GreenPaleBrush}"
                                CornerRadius="6" Padding="8,4">
                            <TextBlock Text="Top 5" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource GreenPrimaryBrush}"/>
                        </Border>
                    </Grid>

                    <!-- Danh sách top khách hàng với layout đẹp hơn DataGrid -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TopKhachHang}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Background="{StaticResource GreenPaleBrush}"
                                            CornerRadius="10"
                                            Padding="14,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Huy hiệu thứ hạng -->
                                            <Border Grid.Column="0"
Width="36" Height="36"
                                                    CornerRadius="18"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#2E7D32" Offset="0"/>
                                                        <GradientStop Color="#4CAF50" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding STT}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Thông tin khách hàng -->
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TenKhachHang}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextDarkBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="📞 " FontSize="11"/>
                                                    <TextBlock Text="{Binding SoDienThoai}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextGrayBrush}"/>
                                                    <TextBlock Text=" · " FontSize="12"
                                                               Foreground="{StaticResource TextGrayBrush}"/>
                                                    <TextBlock Text="{Binding SoLanDat}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource GreenPrimaryBrush}"/>
                                                    <TextBlock Text=" lần đặt" FontSize="12"
Foreground="{StaticResource TextGrayBrush}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Tổng chi tiêu -->
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding TongChiTieuFormatted}"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           Foreground="{StaticResource GreenPrimaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="tổng chi tiêu"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextGrayBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        <!-- ==============================================================
             ROW 4 — STATUS BAR
        ============================================================== -->
        <Border Grid.Row="4"
                Background="{StaticResource GreenPrimaryBrush}"
                Padding="24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Loading indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳" FontSize="13" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Đang tải..."
                               FontSize="12" Foreground="#A5D6A7"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Thông báo trạng thái -->
                <TextBlock Grid.Column="1"
                           Text="{Binding TrangThaiThongBao}"
FontSize="12" Foreground="#A5D6A7"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- Khoảng thời gian đang xem -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Kỳ báo cáo: " FontSize="12"
                               Foreground="#A5D6A7" VerticalAlignment="Center"/>
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:dd/MM/yyyy} — {1:dd/MM/yyyy}">
                                <Binding Path="TuNgay"/>
                                <Binding Path="DenNgay"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
